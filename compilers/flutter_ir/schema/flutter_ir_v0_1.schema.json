{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/flutter_ir_v0_1.schema.json",
  "title": "flutter_ir_v0.1",
  "type": "object",
  "required": ["version", "screens", "components", "tokens", "interactions", "flows", "assets"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "0.1"
    },
    "screens": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/screen"
      }
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/component"
      },
      "default": []
    },
    "tokens": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "interactions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/interactionRef"
      },
      "default": []
    },
    "flows": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/flowGraph"
      },
      "default": []
    },
    "assets": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/asset"
      },
      "default": []
    }
  },
  "definitions": {
    "screen": {
      "type": "object",
      "required": ["id", "name", "root"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "route": { "type": "string" },
        "figmaNodeId": { "type": "string" },
        "root": { "$ref": "#/definitions/node" }
      }
    },
    "component": {
      "type": "object",
      "required": ["id", "name", "root"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "figmaNodeId": { "type": "string" },
        "root": { "$ref": "#/definitions/node" }
      }
    },
    "node": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["frame", "text", "image", "icon", "row", "column", "stack", "container", "button", "list", "pageView"]
        },
        "name": { "type": "string" },
        "props": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "style": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "interaction": {
          "$ref": "#/definitions/interaction"
        },
        "notes": {
          "$ref": "#/definitions/nodeNotes"
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/node" },
          "default": []
        }
      }
    },
    "interaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "onTap": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "type": "string", "enum": ["navigate", "openModal", "none"] },
            "to": { "type": "string" }
          }
        },
        "navigation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": { "type": "string", "enum": ["push", "replace", "reset"] }
          }
        },
        "scroll": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "axis": { "type": "string", "enum": ["vertical", "horizontal"] }
          }
        },
        "gesture": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["swipe", "none"] },
            "axis": { "type": "string", "enum": ["vertical", "horizontal"] }
          }
        },
        "carousel": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "loop": { "type": "boolean" }
          }
        },
        "prototype": {
          "type": "object",
          "required": ["reactions"],
          "additionalProperties": false,
          "properties": {
            "reactions": {
              "type": "array",
              "items": { "$ref": "#/definitions/prototypeReaction" },
              "default": []
            }
          }
        }
      }
    },
    "interactionRef": {
      "type": "object",
      "required": ["id", "targetNodeId", "sourceRootId", "sourceRootName", "payload"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "targetNodeId": { "type": "string" },
        "sourceRootId": { "type": "string" },
        "sourceRootName": { "type": "string" },
        "payload": { "$ref": "#/definitions/interaction" }
      }
    },
    "nodeNotes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "memo": { "type": "string" },
        "sourceMetaNodeId": { "type": "string" },
        "flowStart": { "type": "boolean" },
        "flowId": { "type": "string" }
      }
    },
    "flowGraph": {
      "type": "object",
      "required": ["id", "name", "edges"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "startScreenId": { "type": "string" },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/definitions/flowEdge" },
          "default": []
        }
      }
    },
    "flowEdge": {
      "type": "object",
      "required": ["id", "fromScreenId", "toScreenId", "triggerNodeId", "navigation"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "fromScreenId": { "type": "string" },
        "toScreenId": { "type": "string" },
        "triggerNodeId": { "type": "string" },
        "navigation": { "type": "string" }
      }
    },
    "prototypeReaction": {
      "type": "object",
      "required": ["trigger", "actions"],
      "additionalProperties": false,
      "properties": {
        "trigger": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/definitions/prototypeTrigger" }
          ]
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/prototypeAction" },
          "default": []
        }
      }
    },
    "prototypeTrigger": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "timeout": { "type": "number" },
        "delay": { "type": "number" },
        "device": { "type": "string" },
        "keyCodes": {
          "type": "array",
          "items": { "type": "number" }
        },
        "mediaHitTime": { "type": "number" },
        "deprecatedVersion": { "type": "boolean" }
      }
    },
    "prototypeAction": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "navigation": { "type": "string" },
        "destinationId": { "type": "string" },
        "destinationNodeId": { "type": "string" },
        "destinationName": { "type": "string" },
        "destinationRootId": { "type": "string" },
        "destinationRootNodeId": { "type": "string" },
        "destinationRootName": { "type": "string" },
        "transition": { "$ref": "#/definitions/prototypeTransition" },
        "overlayRelativePosition": {
          "type": "object",
          "required": ["x", "y"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "url": { "type": "string" },
        "openInNewTab": { "type": "boolean" },
        "mediaAction": { "type": "string" },
        "amountToSkip": { "type": "number" },
        "newTimestamp": { "type": "number" },
        "variableId": { "type": "string" },
        "variableCollectionId": { "type": "string" },
        "variableModeId": { "type": "string" },
        "resetVideoPosition": { "type": "boolean" },
        "resetScrollPosition": { "type": "boolean" },
        "resetInteractiveComponents": { "type": "boolean" },
        "preserveScrollPosition": { "type": "boolean" },
        "conditionalBlocks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["actions"],
            "additionalProperties": true,
            "properties": {
              "actions": {
                "type": "array",
                "items": { "$ref": "#/definitions/prototypeAction" }
              }
            }
          }
        }
      }
    },
    "prototypeTransition": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "direction": { "type": "string" },
        "matchLayers": { "type": "boolean" },
        "duration": { "type": "number" },
        "easing": {
          "type": "object",
          "required": ["type"],
          "additionalProperties": true,
          "properties": {
            "type": { "type": "string" },
            "cubicBezier": {
              "type": "object",
              "required": ["x1", "y1", "x2", "y2"],
              "additionalProperties": false,
              "properties": {
                "x1": { "type": "number" },
                "y1": { "type": "number" },
                "x2": { "type": "number" },
                "y2": { "type": "number" }
              }
            },
            "spring": {
              "type": "object",
              "required": ["mass", "stiffness", "damping", "initialVelocity"],
              "additionalProperties": false,
              "properties": {
                "mass": { "type": "number" },
                "stiffness": { "type": "number" },
                "damping": { "type": "number" },
                "initialVelocity": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "asset": {
      "type": "object",
      "required": ["id", "type", "source"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["svg", "png", "jpg"] },
        "source": { "type": "string" }
      }
    }
  }
}
